    "class Solution(object):\n",
    "    def twoSum(self, nums, target):\n",
    "        a = len(nums)\n",
    "        for j in range(0, a - 1):\n",
    "            for i in range(j + 1, a):\n",
    "                if nums[j] + nums[i] == target:\n",
    "                    return [j, i]"
   ]
  }
